MODULE exit_2000 INPUT.
  gv_ok_code = gv_okcode.
  CLEAR: gv_okcode.
  CASE gv_ok_code.
    WHEN 'BACK' OR 'EXIT' OR 'CANC'.
      LEAVE TO SCREEN 0.
  ENDCASE.
ENDMODULE.                 " EXIT_2000  INPUT
